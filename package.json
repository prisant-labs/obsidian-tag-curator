{
  "name": "obsidian-tag-visibility",
  "version": "1.0.0-rc.7",
  "description": "Control which tags are visible across Obsidian's UI: hide, flag, and pin. Display-only, file-safe, fully reversible.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tags"
  ],
  "author": "Prisant Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.5.0",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "private": true
}
